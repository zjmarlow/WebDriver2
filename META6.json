{
    "name": "WebDriver2",
    "description": "WebDriver level 2 bindings",
    "version": "0.0.6",
    "raku": "6.d",
    "auth": "zef:zjmarlow",
    "depends": [
        "JSON::Fast",
        "URI::Encode",
        "HTTP::Status",
		"HTTP::UserAgent::Strict",
        "File::Temp",
        "DateTime::Parse",
        "Encode",
        "MIME::Base64",
        "URI",
        "IO::Socket::SSL"
    ],
    "build-depends": [],
    "test-depends": [
        "PostCocoon::Url"
    ],
    "provides": {
		"Provider": "lib/WD2.rakumod",
		"WD2::Endpoints": "lib/WD2/Endpoints.rakumod",
		"WD2::Endpoints::Execution-Status": "lib/WD2/Endpoints.rakumod",
		"WD2::Endpoints::Error": "lib/WD2/Endpoints.rakumod",
		"WD2::Endpoints::Result::X": "lib/WD2/Endpoints.rakumod",
		"WD2::Component::Driver": "lib/WD2/Component/Driver.rakumod",
		"WD2::Component::Session": "lib/WD2/Component/Session.rakumod",
		"WD2::Component::Element": "lib/WD2/Component/Element.rakumod",
