use Test;

use lib <../http-useragent/lib lib>;

use WD2;
use WD2::Wait;
use WD2::Wait::Common :ALL;
use WD2::Test::Template;
use WD2::Endpoints;
use WD2::Locators;

my IO::Path:D $html-file = .add: 'test.html' with $*CWD.add: <xt content>;

class Wait does WD2::Test::Template {
	has Int:D $.plan = 2;
	has Str:D $.name = 'wait';
	has Str:D $.description = 'various waits';
	
	method pre-test { }
	method post-test { }
	
	method test {
		my Duration:D $duration = Duration.new: 1/2;
		my By:D $locator = By::ID.value: 'added';
		my &wait;
		my WD2::Component::Element $element;
		my Instant $start;
		self.subtest: 'wait present / absent' => {
			plan 10;
			
			self.diag: 'element absent';
			$!session.navigate-to: 'file://' ~ $html-file.absolute;
			self.ok:
					'absent true for absent element',
					.() with absent $!session, $locator, :$duration;
			&wait = absent $!session, $locator, :$duration;
			self.lives-ok:
					'absent returns immediately for absent element',
					&wait;
			self.nok:
					'present times out for absent element',
					.() with present $!session, $locator, :$duration, :soft;
			self.throws-like:
					'present throws correctly when element is absent',
					WD2::Wait::Timeout::X,
					present $!session, $locator, :$duration;
			
			self.diag: 'element becomes present';
			&wait = present $!session, $locator, :soft;
			.click with $!session.find-element: By::ID.value: 'add';
			$element = &wait();
			self.isa-ok:
					'wait for presence returns correct type',
					WD2::Component::Element,
					$element;
			self.ok: 'wait for presence found element', $element;
			self.is: 'found correct type of element', 'button', $element.tag-name;
			self.is: 'found correct element', 'added', $element.id;
			
			self.diag: 'element present';
			&wait = present $!session, $locator, :$duration;
			$start = now;
			$element = &wait();
			self.ok:
					'wait for presence returns immediately if already present',
					now - $start < $duration;
			self.ok: 'immediate presence returned element', $element;
			self.is: 'correct element returned', 'hidden', $element.id;
			self.nok:
					'absent times out for present element',
					.() with absent $!session, $locator, :$duration, :soft;
					
			self.diag: 'element removed';
			$locator = By::ID.value: 'remove';
			$element = $!session.find-element: $locator;
			&wait = absent $!session, $locator, :soft;
			$element.click;
			self.ok: 'element removed', &wait();
			&wait = absent $!session, $locator, :$duration;
			self.lives-ok: 'absent returns immediately if already absent', &wait;
		}
		self.subtest: 'wait stale' => {
			plan 7;
			$!session.refresh;
			$element = .() with present $!session, By::ID.value: 'remove';
			self.ok: 'button starts out present', $element;
			self.nok:
					'not stale while present',
					.() with stale $element, :$duration, :soft;
			self.throws-like:
					'stale times out on present',
					WD2::Wait::Timeout::X,
					stale $element;
			&wait = stale $element;
			$element.click;
			self.is: 'stale', Stale, &wait();
			$locator = $element.locator;
			self.nok: 'element not present', $!session.present: $locator;
			self.nok:
					'wait stale detects element no longer present',
					.() with present $!session, $locator, :soft;
			$start = now;
			&wait();
			self.ok:
					'wait returns immediately if already stale',
					now - $start < $duration;
		}
		self.subtest: 'wait (not-)displayed' => {
			plan 5;
			$!session.refresh;
			$element = $!session.find-element: By::ID.value: 'visible';
			self.ok:
					'displayed detects displayed',
					.() with displayed $element, :$duration;
			self.nok:
					'not-displayed returns false for displayed',
					.() with not-displayed $element, :$duration, :soft;
			self.throws-like:
					'not-displayed times out for displayed',
					WD2::Wait::Timeout::X,
					not-displayed $element;
			&wait = not-displayed;
			$element.click;
			self.ok: 'not-displayed detects no longer displayed', &wait();
			
		}
	}
	
	method element-by-id( Str $id ) {
		$!session.find-element( By::ID.value: $id )
	}
}

constant &MAIN = driver-test Wait;
